generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Validator {
  id        String   @id @default(uuid())
  chainId   String
  address   String
  name      String?
  createdAt DateTime @default(now())

  chain     Chain             @relation(fields: [chainId], references: [id])
  metrics   ValidatorMetric[]
  logs      ValidatorLog[]
  nodes     Node[]

  @@unique([address, chainId])
}

model Chain {
  id         String      @id @default(uuid())
  name       String
  validators Validator[]
}

model Node {
  id          String   @id @default(uuid())
  validatorId String
  status      String

  validator   Validator @relation(fields: [validatorId], references: [id])
}

model ValidatorMetric {
  id          String   @id @default(uuid())
  validatorId String
  slot        Int
  value       Float
  createdAt   DateTime @default(now())

  validator   Validator @relation(fields: [validatorId], references: [id])
}

model ValidatorLog {
  id          String   @id @default(uuid())
  validatorId String
  message     String
  createdAt   DateTime @default(now())

  validator   Validator @relation(fields: [validatorId], references: [id])
}